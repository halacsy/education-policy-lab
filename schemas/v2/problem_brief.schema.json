{
  "$id": "https://education-policy-lab.example/schemas/v2/problem_brief.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "allOf": [
    {"$ref": "https://education-policy-lab.example/schemas/v2/common.schema.json#/$defs/record_envelope"},
    {"properties": {
      "id": {"pattern": "^PB-[A-Za-z0-9._-]+$"},
      "record_type": {"const": "problem_brief"},
      "schema_version": {"const": "2.0.0"},
      "status": {"const": "admitted"},
      "provenance_ref": {"type": "string", "pattern": "^PV-[A-Za-z0-9._-]+$"},
      "content": {
        "type": "object", "additionalProperties": false,
        "properties": {
          "title": {"type": "string", "minLength": 1},
          "public_question": {"type": "string", "minLength": 1},
          "problem_statement": {"type": "string", "minLength": 1},
          "learning_goals": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "scope": {"type": "string", "minLength": 1},
          "seed_sources": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
          "approval_basis": {"type": "string", "minLength": 1}
        },
        "required": ["title", "public_question", "problem_statement", "learning_goals", "scope", "seed_sources", "approval_basis"]
      }
    }}
  ],
  "x-artifact-references": [{"path": "/provenance_ref", "record_type": "provenance"}],
  "x-record-type": "problem_brief",
  "x-schema-version": "2.0.0"
}
