{
  "$id": "https://education-policy-lab.example/schemas/v2/option_space_proposal.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "allOf": [
    {"$ref": "https://education-policy-lab.example/schemas/v2/common.schema.json#/$defs/record_envelope"},
    {"properties": {
      "id": {"pattern": "^OS-[A-Za-z0-9._-]+$"},
      "record_type": {"const": "option_space_proposal"},
      "schema_version": {"const": "2.0.0"},
      "status": {"const": "candidate"},
      "provenance_ref": {"type": "string", "pattern": "^PV-[A-Za-z0-9._-]+$"},
      "content": {
        "type": "object", "additionalProperties": false,
        "properties": {
          "directions": {
            "type": "array", "minItems": 2, "maxItems": 7,
            "items": {
              "type": "object", "additionalProperties": false,
              "properties": {
                "id": {"type": "string", "pattern": "^S[1-9][0-9]*$"},
                "title": {"type": "string", "minLength": 1},
                "scope": {"type": "string", "minLength": 1},
                "finding_refs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^F-[A-Za-z0-9._-]+$"}},
                "option_seed_refs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^OSD-[A-Za-z0-9._-]+$"}}
              },
              "required": ["id", "title", "scope"],
              "oneOf": [
                {"required": ["finding_refs"], "not": {"required": ["option_seed_refs"]}},
                {"required": ["option_seed_refs"], "not": {"required": ["finding_refs"]}}
              ]
            }
          },
          "rejected_framings": {
            "type": "array", "minItems": 1,
            "items": {
              "type": "object", "additionalProperties": false,
              "properties": {
                "framing": {"type": "string", "minLength": 1},
                "reason": {"type": "string", "minLength": 1},
                "finding_refs": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^F-[A-Za-z0-9._-]+$"}},
                "option_seed_refs": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^OSD-[A-Za-z0-9._-]+$"}}
              },
              "required": ["framing", "reason"],
              "oneOf": [
                {"required": ["finding_refs"], "not": {"required": ["option_seed_refs"]}},
                {"required": ["option_seed_refs"], "not": {"required": ["finding_refs"]}}
              ]
            }
          },
          "derivation_notice": {"type": "string", "minLength": 1}
        },
        "required": ["directions", "rejected_framings", "derivation_notice"]
      }
    }}
  ],
  "x-artifact-references": [
    {"path": "/provenance_ref", "record_type": "provenance"},
    {"path": "/content/directions/*/finding_refs/*", "record_type": "finding"},
    {"path": "/content/rejected_framings/*/finding_refs/*", "record_type": "finding"},
    {"path": "/content/directions/*/option_seed_refs/*", "record_type": "option_seed"},
    {"path": "/content/rejected_framings/*/option_seed_refs/*", "record_type": "option_seed"}
  ],
  "x-record-type": "option_space_proposal",
  "x-schema-version": "2.0.0"
}
