{
  "$id": "https://education-policy-lab.example/schemas/v2/common.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "record_envelope": {
      "additionalProperties": false,
      "properties": {
        "content": {},
        "created_at": {
          "format": "date-time",
          "type": "string"
        },
        "id": {
          "pattern": "^[A-Z][A-Z0-9]*-[A-Za-z0-9._-]+$",
          "type": "string"
        },
        "provenance_ref": {
          "oneOf": [
            {
              "pattern": "^PV-[A-Za-z0-9._-]+$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "record_type": {
          "pattern": "^[a-z][a-z0-9_]*$",
          "type": "string"
        },
        "schema_version": {
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
          "type": "string"
        },
        "status": {
          "enum": [
            "candidate",
            "reviewed",
            "admitted",
            "superseded",
            "rejected",
            "retired"
          ]
        },
        "supersedes": {
          "oneOf": [
            {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "topic": {
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
          "type": "string"
        }
      },
      "required": [
        "id",
        "record_type",
        "schema_version",
        "topic",
        "status",
        "content",
        "provenance_ref",
        "created_at",
        "supersedes"
      ],
      "type": "object"
    }
  },
  "title": "Education Policy Lab v2 common schema"
}
