{
  "$id": "https://education-policy-lab.example/schemas/v2/transformation_proposal.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "allOf": [
    {"$ref": "https://education-policy-lab.example/schemas/v2/common.schema.json#/$defs/record_envelope"},
    {"properties": {
      "id": {"pattern": "^TP-[A-Za-z0-9._-]+$"},
      "record_type": {"const": "transformation_proposal"},
      "schema_version": {"const": "2.0.0"},
      "provenance_ref": {"type": "string", "pattern": "^PV-[A-Za-z0-9._-]+$"},
      "content": {
        "type": "object", "additionalProperties": false,
        "properties": {
          "title": {"type": "string", "minLength": 1},
          "goal": {"type": "string", "minLength": 1},
          "change_level": {"enum": ["practice", "organization", "network", "governance", "system"]},
          "mechanisms": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "implementation_steps": {"type": "array", "items": {"type": "object", "additionalProperties": false, "properties": {"actor": {"type": "string", "minLength": 1}, "action": {"type": "string", "minLength": 1}, "timeline": {"type": "string", "minLength": 1}}, "required": ["actor", "action", "timeline"]}},
          "expected_benefits": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "costs": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "risks": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "equity_impact": {"type": "string", "minLength": 1},
          "evidence_status": {"enum": ["strong", "moderate", "weak", "contested", "unknown"]},
          "finding_refs": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^F-[A-Za-z0-9._-]+$"}},
          "assumption_refs": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^A-[A-Za-z0-9._-]+$"}},
          "uncertainty_refs": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^U-[A-Za-z0-9._-]+$"}},
          "legacy_scenario_id": {"type": "string", "pattern": "^S[0-9]+$"}
        },
        "required": ["title", "goal", "change_level", "mechanisms", "implementation_steps", "expected_benefits", "costs", "risks", "equity_impact", "evidence_status", "finding_refs", "assumption_refs", "uncertainty_refs", "legacy_scenario_id"]
      }
    }}
  ],
  "x-artifact-references": [
    {"path": "/provenance_ref", "record_type": "provenance"},
    {"path": "/content/finding_refs/*", "record_type": "finding"},
    {"path": "/content/assumption_refs/*", "record_type": "assumption"},
    {"path": "/content/uncertainty_refs/*", "record_type": "uncertainty"}
  ],
  "x-record-type": "transformation_proposal",
  "x-schema-version": "2.0.0"
}
