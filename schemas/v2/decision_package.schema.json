{
  "$id": "https://education-policy-lab.example/schemas/v2/decision_package.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "allOf": [
    {"$ref": "https://education-policy-lab.example/schemas/v2/common.schema.json#/$defs/record_envelope"},
    {"properties": {
      "id": {"pattern": "^DP-[A-Za-z0-9._-]+$"},
      "record_type": {"const": "decision_package"},
      "schema_version": {"const": "2.0.0"},
      "provenance_ref": {"type": "string", "pattern": "^PV-[A-Za-z0-9._-]+$"},
      "content": {
        "type": "object", "additionalProperties": false,
        "properties": {
          "title": {"type": "string", "minLength": 1},
          "public_question": {"type": "string", "minLength": 1},
          "summary": {"type": "string", "minLength": 1},
          "transformation_family_refs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^TF-[A-Za-z0-9._-]+$"}},
          "proposal_refs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^TP-[A-Za-z0-9._-]+$"}},
          "lens_assessment_refs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^AS-[A-Za-z0-9._-]+$"}},
          "dilemma_refs": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^D-[A-Za-z0-9._-]+$"}},
          "research_question_refs": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^RQ-[A-Za-z0-9._-]+$"}},
          "migration_notice": {"type": "string", "minLength": 1},
          "generation_notice": {"type": "string", "minLength": 1}
        },
        "required": ["title", "public_question", "summary", "transformation_family_refs", "proposal_refs", "lens_assessment_refs", "dilemma_refs", "research_question_refs"],
        "anyOf": [
          {"required": ["migration_notice"]},
          {"required": ["generation_notice"]}
        ]
      }
    }}
  ],
  "x-artifact-references": [
    {"path": "/provenance_ref", "record_type": "provenance"},
    {"path": "/content/transformation_family_refs/*", "record_type": "transformation_family"},
    {"path": "/content/proposal_refs/*", "record_type": "transformation_proposal"},
    {"path": "/content/lens_assessment_refs/*", "record_type": "lens_assessment"},
    {"path": "/content/dilemma_refs/*", "record_type": "dilemma"},
    {"path": "/content/research_question_refs/*", "record_type": "research_question"}
  ],
  "x-record-type": "decision_package",
  "x-schema-version": "2.0.0"
}
