{
  "$id": "https://education-policy-lab.example/schemas/v2/lens_definition.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "allOf": [
    {"$ref": "https://education-policy-lab.example/schemas/v2/common.schema.json#/$defs/record_envelope"},
    {"properties": {
      "id": {"pattern": "^L-[A-Za-z0-9._-]+$"},
      "record_type": {"const": "lens_definition"},
      "schema_version": {"const": "2.0.0"},
      "provenance_ref": {"type": "string", "pattern": "^PV-[A-Za-z0-9._-]+$"},
      "content": {
        "type": "object", "additionalProperties": false,
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "discipline": {"type": "string", "minLength": 1},
          "questions": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "criteria": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "limitations": {"type": "array", "items": {"type": "string", "minLength": 1}}
        },
        "required": ["name", "discipline", "questions", "criteria", "limitations"]
      }
    }}
  ],
  "x-artifact-references": [{"path": "/provenance_ref", "record_type": "provenance"}],
  "x-record-type": "lens_definition",
  "x-schema-version": "2.0.0"
}
