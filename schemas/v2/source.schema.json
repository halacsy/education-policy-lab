{
  "$id": "https://education-policy-lab.example/schemas/v2/source.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "allOf": [
    {
      "$ref": "https://education-policy-lab.example/schemas/v2/common.schema.json#/$defs/record_envelope"
    },
    {
      "properties": {
        "content": {
          "additionalProperties": false,
          "properties": {
            "accessed_at": {
              "format": "date-time",
              "type": "string"
            },
            "license_status": {
              "enum": [
                "open",
                "public_pointer_only",
                "permission_required",
                "unknown"
              ]
            },
            "source_type": {
              "enum": [
                "dataset",
                "law",
                "policy_document",
                "research_paper",
                "report",
                "web_page"
              ]
            },
            "title": {
              "minLength": 1,
              "type": "string"
            },
            "url": {
              "format": "uri",
              "type": "string"
            }
          },
          "required": [
            "title",
            "url",
            "source_type",
            "license_status",
            "accessed_at"
          ],
          "type": "object"
        },
        "id": {
          "pattern": "^SRC-[A-Za-z0-9._-]+$"
        },
        "provenance_ref": {
          "pattern": "^PV-[A-Za-z0-9._-]+$",
          "type": "string"
        },
        "record_type": {
          "const": "source"
        },
        "schema_version": {
          "const": "2.0.0"
        }
      }
    }
  ],
  "title": "Source artifact",
  "x-artifact-references": [
    {
      "path": "/provenance_ref",
      "record_type": "provenance"
    }
  ],
  "x-record-type": "source",
  "x-schema-version": "2.0.0"
}
