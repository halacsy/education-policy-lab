{
  "$id": "https://education-policy-lab.example/schemas/v2/dilemma.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "allOf": [
    {"$ref": "https://education-policy-lab.example/schemas/v2/common.schema.json#/$defs/record_envelope"},
    {"properties": {
      "id": {"pattern": "^D-[A-Za-z0-9._-]+$"},
      "record_type": {"const": "dilemma"},
      "schema_version": {"const": "2.0.0"},
      "provenance_ref": {"type": "string", "pattern": "^PV-[A-Za-z0-9._-]+$"},
      "content": {
        "type": "object", "additionalProperties": false,
        "properties": {
          "title": {"type": "string", "minLength": 1},
          "tension": {"type": "string", "minLength": 1},
          "dilemma_type": {"enum": ["value_conflict", "irreducible_tradeoff", "mixed", "empirical_open_question"]},
          "value_poles": {"type": "array", "minItems": 2, "items": {"type": "string", "minLength": 1}},
          "affected_groups": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "decision_question": {"type": "string", "minLength": 1},
          "evidence_boundary": {"type": "string", "minLength": 1},
          "proposal_refs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^TP-[A-Za-z0-9._-]+$"}},
          "finding_refs": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^F-[A-Za-z0-9._-]+$"}},
          "legacy_cluster_id": {"type": "string", "pattern": "^A[0-9]+$"},
          "origin": {"enum": ["live_generation", "v1_migration"]}
        },
        "required": ["title", "tension", "dilemma_type", "value_poles", "affected_groups", "decision_question", "evidence_boundary", "proposal_refs", "finding_refs"]
      }
    }}
  ],
  "x-artifact-references": [
    {"path": "/provenance_ref", "record_type": "provenance"},
    {"path": "/content/proposal_refs/*", "record_type": "transformation_proposal"},
    {"path": "/content/finding_refs/*", "record_type": "finding"}
  ],
  "x-record-type": "dilemma",
  "x-schema-version": "2.0.0"
}
