{
  "$id": "https://education-policy-lab.example/schemas/v2/evidence_conflict.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "allOf": [
    {"$ref": "https://education-policy-lab.example/schemas/v2/common.schema.json#/$defs/record_envelope"},
    {"properties": {
      "id": {"pattern": "^EC-[A-Za-z0-9._-]+$"},
      "record_type": {"const": "evidence_conflict"},
      "schema_version": {"const": "2.0.0"},
      "provenance_ref": {"type": "string", "pattern": "^PV-[A-Za-z0-9._-]+$"},
      "content": {
        "type": "object", "additionalProperties": false,
        "properties": {
          "title": {"type": "string", "minLength": 1},
          "conflict_type": {"enum": ["direct_contradiction", "context_dependence", "measurement_difference", "temporal_change", "causal_interpretation", "population_difference", "transferability"]},
          "description": {"type": "string", "minLength": 1},
          "resolvability": {"enum": ["answerable_now", "requires_new_data", "context_specific", "not_empirically_resolvable"]},
          "research_question": {"type": "string", "minLength": 1},
          "decision_relevance": {"type": "string", "minLength": 1},
          "finding_refs": {"type": "array", "minItems": 2, "uniqueItems": true, "items": {"type": "string", "pattern": "^F-[A-Za-z0-9._-]+$"}},
          "canonical_claim_refs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^CC-[A-Za-z0-9._-]+$"}}
        },
        "required": ["title", "conflict_type", "description", "resolvability", "research_question", "decision_relevance", "finding_refs", "canonical_claim_refs"]
      }
    }}
  ],
  "x-artifact-references": [
    {"path": "/provenance_ref", "record_type": "provenance"},
    {"path": "/content/finding_refs/*", "record_type": "finding"},
    {"path": "/content/canonical_claim_refs/*", "record_type": "canonical_claim"}
  ],
  "x-record-type": "evidence_conflict",
  "x-schema-version": "2.0.0"
}
